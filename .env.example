# Cresus Server Configuration

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# MCP Server (Model Context Protocol)
MCP_HOST=localhost
MCP_PORT=3000

# Frontend Server
FRONT_HOST=localhost
FRONT_PORT=5173

# Gateway Settings
GATEWAY_CRON_ENABLED=false
GATEWAY_MCP_ENABLED=true
GATEWAY_CRON_CONFIG=config/cron.yml

# Project Configuration
CRESUS_PROJECT_ROOT=/Volumes/Data/dev/cresus
CRESUS_LOG_LEVEL=INFO

# GSheet credentials (optional)
GSHEET_CREDENTIALS_PATH=~/.config/cresus/gsheet_credentials.json

# Broker Credentials (optional)
BOURSEDIRECT_USERNAME=
BOURSEDIRECT_PASSWORD=
