# Cresus Environment Configuration
# Copy this to ~/.cresus/.env and customize as needed

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# MCP Server Configuration
MCP_HOST=localhost
MCP_PORT=3000

# Frontend Configuration
FRONT_HOST=localhost
FRONT_PORT=5173

# Gateway Configuration
GATEWAY_CRON_ENABLED=true
GATEWAY_MCP_ENABLED=true

# Optional: Override default locations (uncomment to use)
# CRESUS_DB_ROOT=/custom/path/to/db
# CRESUS_CONFIG_ROOT=/custom/path/to/config
# CRESUS_ENV_FILE=/custom/path/to/.env
