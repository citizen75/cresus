[
  {
    "name": "load_strategy",
    "description": "Load complete strategy configuration from YAML file",
    "category": "read",
    "type": "function",
    "input_schema": {
      "type": "object",
      "properties": {
        "strategy_name": {
          "type": "string",
          "description": "Name of strategy to load (matches strategy.name in YAML, not filename)"
        }
      },
      "required": ["strategy_name"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error", "not_found"],
          "description": "Operation status"
        },
        "data": {
          "type": "object",
          "description": "Full strategy configuration including all sections"
        },
        "name": {
          "type": "string",
          "description": "Strategy name"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description"
        },
        "source": {
          "type": "string",
          "description": "Market data source (e.g., 'cac40', 'nasdaq_100')"
        },
        "message": {
          "type": "string",
          "description": "Error message on failure"
        }
      },
      "required": ["status"]
    }
  },
  {
    "name": "list_all_strategies",
    "description": "List all available trading strategies with metadata",
    "category": "read",
    "type": "function",
    "input_schema": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error"],
          "description": "Operation status"
        },
        "strategies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string", "description": "Internal strategy name"},
              "description": {"type": "string"},
              "source": {"type": "string", "description": "Market source (e.g., 'cac40')"},
              "file": {"type": "string", "description": "YAML filename"}
            }
          },
          "description": "List of all strategies with metadata"
        },
        "total_count": {
          "type": "integer",
          "description": "Total number of strategies"
        },
        "message": {
          "type": "string",
          "description": "Error message on failure"
        }
      },
      "required": ["status", "strategies", "total_count"]
    }
  },
  {
    "name": "get_strategies_by_source",
    "description": "Get all strategies filtered by market data source",
    "category": "read",
    "type": "function",
    "input_schema": {
      "type": "object",
      "properties": {
        "source_name": {
          "type": "string",
          "description": "Market source name (e.g., 'cac40', 'nasdaq_100', 'dax')"
        }
      },
      "required": ["source_name"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error"],
          "description": "Operation status"
        },
        "source": {
          "type": "string",
          "description": "The requested source name"
        },
        "strategies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "description": {"type": "string"},
              "has_momentum_config": {"type": "boolean"},
              "file": {"type": "string"}
            }
          }
        },
        "total_count": {
          "type": "integer",
          "description": "Number of strategies for this source"
        },
        "message": {
          "type": "string",
          "description": "Error message on failure"
        }
      },
      "required": ["status", "source", "strategies", "total_count"]
    }
  },
  {
    "name": "find_strategy_by_name",
    "description": "Find strategy by internal name (handles filename/name mismatch)",
    "category": "read",
    "type": "function",
    "input_schema": {
      "type": "object",
      "properties": {
        "strategy_name": {
          "type": "string",
          "description": "Internal strategy name to find"
        }
      },
      "required": ["strategy_name"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error", "not_found"],
          "description": "Operation status"
        },
        "data": {
          "type": "object",
          "description": "Strategy configuration data"
        },
        "name": {
          "type": "string",
          "description": "Strategy name"
        },
        "description": {
          "type": "string",
          "description": "Strategy description"
        },
        "source": {
          "type": "string",
          "description": "Market source"
        },
        "file": {
          "type": "string",
          "description": "YAML filename where strategy is defined"
        },
        "message": {
          "type": "string",
          "description": "Error or not found message"
        }
      },
      "required": ["status"]
    }
  },
  {
    "name": "validate_strategy_config",
    "description": "Validate strategy configuration for completeness and correctness",
    "category": "read",
    "type": "function",
    "input_schema": {
      "type": "object",
      "properties": {
        "strategy_name": {
          "type": "string",
          "description": "Strategy name to validate"
        }
      },
      "required": ["strategy_name"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error"],
          "description": "Operation status"
        },
        "strategy": {
          "type": "string",
          "description": "The validated strategy name"
        },
        "valid": {
          "type": "boolean",
          "description": "Whether strategy is valid"
        },
        "issues": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of validation issues found"
        },
        "issue_count": {
          "type": "integer",
          "description": "Number of issues"
        },
        "message": {
          "type": "string",
          "description": "Error message on failure"
        }
      },
      "required": ["status", "valid", "issues"]
    }
  },
  {
    "name": "get_strategy_agent_config",
    "description": "Extract specific agent configuration from a strategy",
    "category": "read",
    "type": "function",
    "input_schema": {
      "type": "object",
      "properties": {
        "strategy_name": {
          "type": "string",
          "description": "Strategy name"
        },
        "agent_name": {
          "type": "string",
          "description": "Agent name (e.g., 'MomentumScoringAgent')"
        }
      },
      "required": ["strategy_name", "agent_name"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error", "not_found"],
          "description": "Operation status"
        },
        "config": {
          "type": "object",
          "description": "Agent-specific configuration"
        },
        "strategy": {
          "type": "string",
          "description": "Strategy name"
        },
        "agent": {
          "type": "string",
          "description": "Agent name"
        },
        "available_agents": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of available agents (if requested agent not found)"
        },
        "message": {
          "type": "string",
          "description": "Error or not found message"
        }
      },
      "required": ["status"]
    }
  },
  {
    "name": "get_momentum_scoring_config",
    "description": "Get momentum-specific parameters from strategy",
    "category": "read",
    "type": "function",
    "input_schema": {
      "type": "object",
      "properties": {
        "strategy_name": {
          "type": "string",
          "description": "Strategy name to get momentum config from"
        }
      },
      "required": ["strategy_name"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error"],
          "description": "Operation status"
        },
        "strategy_name": {
          "type": "string",
          "description": "The strategy name"
        },
        "parameters": {
          "type": "object",
          "description": "Momentum scoring parameters (windows, weights, regime adjustments, normalization)"
        },
        "data": {
          "type": "object",
          "properties": {
            "tickers": {
              "type": "array",
              "items": {"type": "string"},
              "description": "List of tickers for this strategy"
            },
            "windows": {"type": "object", "description": "Time windows for momentum calculation"},
            "weights": {"type": "object", "description": "Weights for different term windows"}
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "strategy_id": {"type": "string"},
            "agent": {"type": "string"},
            "version": {"type": "string"}
          }
        },
        "message": {
          "type": "string",
          "description": "Error message on failure"
        }
      },
      "required": ["status"]
    }
  },
  {
    "name": "create_strategy",
    "description": "Create new strategy configuration file",
    "category": "write",
    "type": "function",
    "confirmation_required": false,
    "input_schema": {
      "type": "object",
      "properties": {
        "strategy_name": {
          "type": "string",
          "description": "Name for the new strategy"
        },
        "filename": {
          "type": "string",
          "description": "YAML filename for strategy (e.g., 'my_strategy.yml')"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of strategy"
        },
        "source": {
          "type": "string",
          "description": "Market data source (e.g., 'cac40', 'nasdaq_100')"
        },
        "config": {
          "type": "object",
          "description": "Strategy configuration template/overrides"
        }
      },
      "required": ["strategy_name", "filename"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error", "conflict"],
          "description": "Operation status"
        },
        "strategy": {
          "type": "string",
          "description": "The created strategy name"
        },
        "file": {
          "type": "string",
          "description": "Path to created YAML file"
        },
        "message": {
          "type": "string",
          "description": "Success or error message"
        }
      },
      "required": ["status", "strategy"]
    }
  },
  {
    "name": "update_strategy",
    "description": "Modify existing strategy configuration",
    "category": "write",
    "type": "function",
    "confirmation_required": true,
    "input_schema": {
      "type": "object",
      "properties": {
        "strategy_name": {
          "type": "string",
          "description": "Name of strategy to update"
        },
        "updates": {
          "type": "object",
          "description": "Fields to update (uses dot notation for nested fields: 'exit_strategy.stop_loss': 0.03)"
        }
      },
      "required": ["strategy_name", "updates"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error", "not_found"],
          "description": "Operation status"
        },
        "strategy": {
          "type": "string",
          "description": "The updated strategy name"
        },
        "updated_fields": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of fields that were updated"
        },
        "message": {
          "type": "string",
          "description": "Success or error message"
        }
      },
      "required": ["status", "strategy"]
    }
  },
  {
    "name": "delete_strategy",
    "description": "Delete a strategy configuration file (requires confirmation)",
    "category": "write",
    "type": "function",
    "confirmation_required": true,
    "input_schema": {
      "type": "object",
      "properties": {
        "strategy_name": {
          "type": "string",
          "description": "Name of strategy to delete"
        }
      },
      "required": ["strategy_name"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error", "not_found"],
          "description": "Operation status"
        },
        "strategy": {
          "type": "string",
          "description": "The deleted strategy name"
        },
        "deleted_file": {
          "type": "string",
          "description": "Path to deleted file"
        },
        "message": {
          "type": "string",
          "description": "Success or error message"
        }
      },
      "required": ["status", "strategy"]
    }
  },
  {
    "name": "clone_strategy",
    "description": "Create new strategy by cloning existing strategy",
    "category": "write",
    "type": "function",
    "confirmation_required": false,
    "input_schema": {
      "type": "object",
      "properties": {
        "source_strategy": {
          "type": "string",
          "description": "Name of strategy to clone from"
        },
        "new_name": {
          "type": "string",
          "description": "Name for cloned strategy"
        },
        "new_file": {
          "type": "string",
          "description": "YAML filename for cloned strategy (e.g., 'cloned_strategy.yml')"
        }
      },
      "required": ["source_strategy", "new_name", "new_file"]
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error", "not_found", "conflict"],
          "description": "Operation status"
        },
        "new_strategy": {
          "type": "string",
          "description": "Name of cloned strategy"
        },
        "new_file": {
          "type": "string",
          "description": "Path to cloned YAML file"
        },
        "source_strategy": {
          "type": "string",
          "description": "Original strategy name"
        },
        "message": {
          "type": "string",
          "description": "Success or error message"
        }
      },
      "required": ["status"]
    }
  }
]
